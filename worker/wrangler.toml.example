name = "yoke"
main = "dist/worker.js"
compatibility_date = "2024-12-01"
# account_id = "your-cloudflare-account-id"

[vars]
# Set to your production URL so the worker can analyze itself (CF Workers can't fetch their own domain)
# BASE_URL = "https://yourdomain.com"

[assets]
directory = "../client/dist"
binding = "ASSETS"

[[d1_databases]]
binding = "DB"
database_name = "yoke-cache"
# database_id = "your-yoke-cache-database-id"

[[d1_databases]]
binding = "STATS_DB"
database_name = "yoke-stats"
# database_id = "your-yoke-stats-database-id"

# Uncomment and set for custom domain routing:
# [[routes]]
# pattern = "yourdomain.com/*"
# zone_name = "yourdomain.com"

# OG image rendering worker (SVG→PNG via resvg-wasm service binding)
# Deploy og-worker/ first, then uncomment:
# [[services]]
# binding = "OG_WORKER"
# service = "yoke-og"

# KV namespace for reference data (retire.js DB, third-party patterns)
# Create with: npx wrangler kv namespace create REFERENCE_DATA
# [[kv_namespaces]]
# binding = "REFERENCE_DATA"
# id = "your-kv-namespace-id"
