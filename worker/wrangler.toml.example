name = "yoke"
main = "dist/worker.js"
compatibility_date = "2024-12-01"
# account_id = "your-cloudflare-account-id"

[vars]
# Set to your production URL so the worker can analyze itself
# BASE_URL = "https://yourdomain.com"

[assets]
directory = "../client/dist"
binding = "ASSETS"

# D1 — historical scores + analytics (the only database you need)
[[d1_databases]]
binding = "STATS_DB"
database_name = "yoke-stats"
# database_id = "your-yoke-stats-database-id"

# KV — analysis cache + rate limiting + reference data
# Create with: npx wrangler kv namespace create REFERENCE_DATA
[[kv_namespaces]]
binding = "REFERENCE_DATA"
# id = "your-kv-namespace-id"

# Custom domain routing
# [[routes]]
# pattern = "yourdomain.com/*"
# zone_name = "yourdomain.com"

# OG image rendering worker (SVG→PNG via resvg-wasm service binding)
# Deploy og-worker/ first, then uncomment:
# [[services]]
# binding = "OG_WORKER"
# service = "yoke-og"
