#!/bin/sh
# Pre-commit hook: verify lockfiles are fresh
# Runs `bun install --frozen-lockfile` in each workspace root.
# If a lockfile is stale, the commit is blocked with instructions.

set -e

check_lockfile() {
  dir="$1"
  if [ -f "$dir/package.json" ]; then
    if ! (cd "$dir" && bun install --frozen-lockfile) >/dev/null 2>&1; then
      echo ""
      echo "❌ Lockfile out of date in $dir/"
      echo "   Run: cd $dir && bun install"
      echo "   Then stage the updated bun.lockb and commit again."
      echo ""
      exit 1
    fi
  fi
}

check_lockfile "."
check_lockfile "client"
check_lockfile "worker"
