#!/bin/sh
# Pre-commit hook: lint staged files + verify lockfiles are fresh

set -e

# ── Biome: lint & format check on staged files ──
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json)$' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "Running Biome on staged files..."
  npx @biomejs/biome check --no-errors-on-unmatched --staged . || {
    echo ""
    echo "❌ Biome found errors. Fix them before committing."
    echo "   Run: npx @biomejs/biome check --write ."
    echo ""
    exit 1
  }
fi

# ── Lockfile freshness ──
check_lockfile() {
  dir="$1"
  if [ -f "$dir/package.json" ]; then
    if ! (cd "$dir" && bun install --frozen-lockfile) >/dev/null 2>&1; then
      echo ""
      echo "❌ Lockfile out of date in $dir/"
      echo "   Run: cd $dir && bun install"
      echo "   Then stage the updated bun.lockb and commit again."
      echo ""
      exit 1
    fi
  fi
}

check_lockfile "."
check_lockfile "client"
check_lockfile "worker"
