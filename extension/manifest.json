{
  "manifest_version": 3,
  "name": "Yoke — Domain Intelligence",
  "version": "1.2.0",
  "description": "Analyze any domain instantly — DNS, SSL, WHOIS, security, tech stack, performance, and more.",
  "permissions": ["activeTab", "sidePanel", "storage"],
  "action": {
    "default_title": "Analyze this domain",
    "default_icon": {
      "16": "icons/ox/icon16.png",
      "32": "icons/ox/icon32.png",
      "48": "icons/ox/icon48.png",
      "128": "icons/ox/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/ox/icon16.png",
    "48": "icons/ox/icon48.png",
    "128": "icons/ox/icon128.png"
  }
}
