# Copy this to fly.toml and customize for your deployment.
app = "your-app-name"
primary_region = "sjc"  # Change to your preferred region

[build]

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  size = "shared-cpu-1x"
  memory = 256
